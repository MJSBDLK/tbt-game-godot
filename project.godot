; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="TBT Game"
config/description="Tactical Battle RPG - Pokemon meets Fire Emblem"
run/main_scene="res://scenes/battle/maps/test_map_01.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

DebugConfig="*res://scripts/core/debug_config.gd"
TerrainDataManager="*res://scripts/grid/terrain_data_manager.gd"
GridManager="*res://scripts/grid/grid_manager.gd"
TypeChartManager="*res://scripts/combat/type_chart_manager.gd"
StatusEffectSystem="*res://scripts/combat/status_effect_system.gd"
GameStateManager="*res://scripts/managers/game_state_manager.gd"
InputManager="*res://scripts/managers/input_manager.gd"
ActionMenuManager="*res://scripts/managers/action_menu_manager.gd"
TurnManager="*res://scripts/managers/turn_manager.gd"
UIManager="*res://scripts/ui/ui_manager.gd"
VisualFeedbackManager="*res://scripts/ui/visual_feedback_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="viewport"
window/stretch/scale=4.0
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="TBT Game"

[editor_plugins]

enabled=PackedStringArray("res://addons/AsepriteWizard/plugin.cfg", "res://addons/aseprite_tag_exporter/plugin.cfg", "res://addons/codeandweb.texturepacker/plugin.cfg")

